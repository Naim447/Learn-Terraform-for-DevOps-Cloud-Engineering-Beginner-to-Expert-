Check location:	ls ~/.kube/config
Expected:	/home/ubuntu/.kube/config
________________________________________
STEP 9: Create Provider Configuration
provider.tf
terraform {
  required_providers {
    kubernetes = {
      source = "hashicorp/kubernetes"
      version = "~> 2.30"
    }
  }
}

provider "kubernetes" {
  config_path = "~/.kube/config"
}
________________________________________
STEP 10: Create Namespace
namespace.tf
resource "kubernetes_namespace" "dev" {
  metadata {
    name = "dev"
  }
}
________________________________________
STEP 11: Create Deployment
deployment.tf
resource "kubernetes_deployment" "nginx" {

  metadata {
    name      = "nginx-deployment"
    namespace = kubernetes_namespace.dev.metadata[0].name

    labels = {
      app = "nginx"
    }
  }

  spec {

    replicas = 2

    selector {
      match_labels = {
        app = "nginx"
      }
    }

    template {

      metadata {
        labels = {
          app = "nginx"
        }
      }

      spec {

        container {

          image = "nginx:latest"
          name  = "nginx"

          port {
            container_port = 80
          }
        }
      }
    }
  }
}
________________________________________
STEP 12: Create Service
service.tf
resource "kubernetes_service" "nginx" {

  metadata {
    name      = "nginx-service"
    namespace = kubernetes_namespace.dev.metadata[0].name
  }

  spec {

    selector = {
      app = "nginx"
    }

    port {
      port        = 80
      target_port = 80
      node_port   = 32767
    }

    type = "NodePort"
  }
}
________________________________________
STEP 13: Outputs
outputs.tf
output "service_name" {
  value = kubernetes_service.nginx.metadata[0].name
}

output "namespace" {
  value = kubernetes_namespace.dev.metadata[0].name
}
